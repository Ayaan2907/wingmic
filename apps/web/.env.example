# ── Database (libSQL / Turso) ────────────────────────────────────────────
# Local dev: leave blank (defaults to file:./local.db).
# Prod (Turso):
#   TURSO_DB_URL=libsql://your-db-name.turso.io
#   TURSO_AUTH_TOKEN=eyJ...
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# ── Authentication (BetterAuth) ──────────────────────────────────────────
# Generate a random 32+ byte secret: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3210
# Public mirror of BETTER_AUTH_URL for the client-side auth client.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3210

# ── Email (Resend) — for magic links ─────────────────────────────────────
# Local dev: leave RESEND_API_KEY blank — magic links log to dev-server console.
# Prod: API key + verified sending domain at resend.com.
RESEND_API_KEY=
# Sender display name + address. Default: `wingmic <auth@wingmic.xyz>`.
# Override with your verified domain in prod.
RESEND_FROM=

# ── LLM provider — Anthropic Claude (entity extraction) ──────────────────
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6.
ANTHROPIC_EXTRACTION_MODEL=

# ── LLM provider — OpenAI (text-embedding-3-small for entity + recall) ───
OPENAI_API_KEY=
# Optional override; defaults to text-embedding-3-small.
OPENAI_EMBEDDING_MODEL=

# ── Public app URL ───────────────────────────────────────────────────────
# Used by the tRPC client for server-side base URL resolution.
# Production: https://wingmic.xyz (no trailing slash).
NEXT_PUBLIC_APP_URL=

# ── Runtime ──────────────────────────────────────────────────────────────
# NODE_ENV is set by Next.js / Bun automatically. PORT defaults to 3210.
# CI=true is set by GitHub Actions automatically.
